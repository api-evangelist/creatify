            ],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{baseUrl}}/custom_templates/", "host": ["{{baseUrl}}"], "path": ["custom_templates", ""] },
            "description": "Generate a video from a customizable template. Modeled path - verify against docs.creatify.ai."
          }
        }
      ]
    },
    {
      "name": "Product-to-Video (modeled)",
      "item": [
        {
          "name": "Create a video ad from product images",
          "request": {
