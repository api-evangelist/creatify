            "url": { "raw": "{{baseUrl}}/product_to_video/", "host": ["{{baseUrl}}"], "path": ["product_to_video", ""] },
            "description": "Generate a studio-quality video ad from product images. Modeled path - verify against docs.creatify.ai."
          }
        }
      ]
    },
    {
      "name": "Text-to-Speech",
      "item": [
        {
          "name": "Generate speech from text",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-API-ID", "value": "{{apiId}}" },
