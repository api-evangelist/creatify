              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"script\": \"Hello from Creatify.\",\n  \"accent\": null,\n  \"webhook_url\": null\n}" },
            "url": { "raw": "{{baseUrl}}/text_to_speech/", "host": ["{{baseUrl}}"], "path": ["text_to_speech", ""] },
            "description": "Generate an ultra-realistic voiceover from text (up to 8000 chars). 1 credit per 30 seconds."
          }
        },
        {
          "name": "Get a text-to-speech job",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-ID", "value": "{{apiId}}" },
